# BLOCK: Multi-stage Docker Build
# Demonstrates block parsing in Dockerfile format
# Uses # for comments

# SUBBLOCK1: Build Stage
FROM node:18-alpine AS builder

WORKDIR /app

# SUBBLOCK2: Dependencies
COPY package*.json ./
RUN npm ci

# SUBBLOCK2: Build Application
COPY . .
RUN npm run build

# SUBBLOCK1: Runtime Stage
FROM node:18-alpine

WORKDIR /app

# SUBBLOCK2: Runtime Dependencies
RUN apk add --no-cache dumb-init
COPY package*.json ./
RUN npm ci --only=production

# SUBBLOCK2: Copy Built Application
COPY --from=builder /app/dist ./dist

# SUBBLOCK1: Health Check
HEALTHCHECK --interval=30s --timeout=3s --start-period=5s --retries=3 \
  CMD node -e "require('http').get('http://localhost:3000/health')"

# SUBBLOCK1: Entrypoint Configuration
EXPOSE 3000
USER node
ENTRYPOINT ["dumb-init", "--"]
CMD ["node", "dist/index.js"]
