{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "npm: watch",
			"type": "shell",
			"command": "npm",
			"args": ["run", "watch"],
			"isBackground": true,
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"problemMatcher": {
				"pattern": {
					"regexp": "^([a-zA-Z]\\:)?([^:]+):(\\d+):(\\d+): (error|warning|info) TS(\\d+): (.*)$",
					"file": 2,
					"location": 3,
					"endLine": 3,
					"message": 7
				},
				"background": {
					"activeOnStart": true,
					"beginsPattern": "^\\s*npm info it worked",
					"endsPattern": "^\\s*npm notice"
				}
			}
		},
		{
			"label": "npm: compile",
			"type": "shell",
			"command": "npm",
			"args": ["run", "compile"],
			"group": "build",
			"problemMatcher": "$tsc"
		}
	]
}
